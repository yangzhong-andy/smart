{
  "name": "smart-erp",
  "version": "1.1.35",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:sync": "prisma generate && prisma db push",
    "dev:client-a": "npx env-cmd -f .env.client-a next dev",
    "dev:client-b": "npx env-cmd -f .env.client-b next dev",
    "dev:client-c": "npx env-cmd -f .env.client-c next dev",
    "dev:client-d": "npx env-cmd -f .env.client-d next dev",
    "db:push:client-a": "npx env-cmd -f .env.client-a prisma db push",
    "db:push:client-b": "npx env-cmd -f .env.client-b prisma db push",
    "db:push:client-c": "npx env-cmd -f .env.client-c prisma db push",
    "db:push:client-d": "npx env-cmd -f .env.client-d prisma db push",
    "db:migrate:client-a": "npx env-cmd -f .env.client-a prisma migrate deploy",
    "db:migrate:client-b": "npx env-cmd -f .env.client-b prisma migrate deploy",
    "db:migrate:client-c": "npx env-cmd -f .env.client-c prisma migrate deploy",
    "db:migrate:client-d": "npx env-cmd -f .env.client-d prisma migrate deploy",
    "fix:warehouse-type": "node scripts/add-warehouse-type.js",
    "fix:inventory-log": "node scripts/add-inventory-log-table.js"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.26.1",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.562.0",
    "next": "^14.2.18",
    "next-auth": "^4.24.13",
    "react": "18.3.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "swr": "^2.3.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@prisma/client": "5.19.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.11.30",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.18",
    "postcss": "8.4.38",
    "prisma": "5.19.1",
    "env-cmd": "^10.1.0",
    "tailwindcss": "3.4.3",
    "ts-node": "^10.9.2",
    "typescript": "5.5.3"
  }
}
