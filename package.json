{
  "name": "smart-erp",
  "version": "1.7.25",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "build:with-db": "prisma generate && prisma db push && node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:local": "npx env-cmd -f .env.local prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:sync": "prisma generate && prisma db push",
    "dev:baxi": "npx env-cmd -f .env.baxi next dev",
    "dev:hangguo": "npx env-cmd -f .env.hangguo next dev",
    "dev:petaboo": "npx env-cmd -f .env.petaboo next dev",
    "dev:sdfy": "npx env-cmd -f .env.sdfy next dev",
    "db:push:baxi": "npx env-cmd -f .env.baxi prisma db push",
    "db:push:hangguo": "npx env-cmd -f .env.hangguo prisma db push",
    "db:push:petaboo": "npx env-cmd -f .env.petaboo prisma db push",
    "db:push:sdfy": "npx env-cmd -f .env.sdfy prisma db push",
    "db:migrate:baxi": "npx env-cmd -f .env.baxi prisma migrate deploy",
    "db:migrate:hangguo": "npx env-cmd -f .env.hangguo prisma migrate deploy",
    "db:baseline:hangguo": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prisma-baseline-resolve.ps1",
    "build:hangguo": "npx env-cmd -f .env.hangguo npx prisma generate && npx env-cmd -f .env.hangguo npx prisma db push && npx env-cmd -f .env.hangguo npx next build",
    "start:hangguo": "npx env-cmd -f .env.hangguo next start",
    "db:migrate:petaboo": "npx env-cmd -f .env.petaboo prisma migrate deploy",
    "db:migrate:sdfy": "npx env-cmd -f .env.sdfy prisma migrate deploy",
    "db:migrate:all-envs": "npm run db:migrate:baxi && npm run db:migrate:hangguo && npm run db:migrate:petaboo && npm run db:migrate:sdfy",
    "fix:warehouse-type": "node scripts/add-warehouse-type.js",
    "fix:inventory-log": "node scripts/add-inventory-log-table.js",
    "dedupe:tail-expenses": "npx ts-node scripts/dedupe-pending-tail-expenses.ts",
    "backfill:contract-variants": "npx tsx scripts/backfill-contract-item-variant-links.ts",
    "remediate:inventory": "npx tsx scripts/remediate-inventory-and-contract-skus.ts",
    "fix:brush-stock": "npx tsx scripts/fix-brush-stock-targets.ts",
    "move:brush-sea": "npx tsx scripts/move-brush-stock-to-sea-transit.ts",
    "clear:domestic-stock": "npx tsx scripts/clear-domestic-warehouse-stock.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.26.1",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.562.0",
    "next": "^14.2.18",
    "next-auth": "^4.24.13",
    "react": "18.3.1",
    "react-day-picker": "^9.13.0",
    "react-dom": "18.3.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "swr": "^2.3.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@prisma/client": "5.19.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "20.11.30",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.18",
    "postcss": "8.4.38",
    "prisma": "5.19.1",
    "env-cmd": "^10.1.0",
    "tailwindcss": "3.4.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.5.3"
  }
}

