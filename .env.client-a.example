# 系统 A（默认/当前）环境变量
# 使用：复制为 .env.client-a 并填写实际值（.env.client-a 已加入 .gitignore）

# 数据库连接（必填）
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
# 或 MySQL: mysql://user:password@host:3306/dbname

# 汇率 API（可选）
# EXCHANGERATE_API_KEY="your-api-key-here"

# 本公司信息（可选，用于采购合同等）
# COMPANY_NAME="公司全称"
# COMPANY_ADDRESS="公司地址"
# COMPANY_PHONE="联系电话"
# COMPANY_CONTACT="联系代表/签字人"
# COMPANY_BANK_ACCOUNT="付款账号卡号"
# COMPANY_BANK_ACCOUNT_NAME="付款账号户名"
# COMPANY_BANK_NAME="开户行"
# COMPANY_TAX_ID="税号"
