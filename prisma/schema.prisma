generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdAccount {
  id               String          @id
  agencyId         String
  agencyName       String?
  accountName       String
  platformAccountId String?
  storeId           String?
  storeName         String?
  currentBalance   Decimal         @default(0) @db.Decimal(18, 2)
  rebateReceivable Decimal         @default(0) @db.Decimal(18, 2)
  creditLimit      Decimal         @default(0) @db.Decimal(18, 2)
  currency         String
  country          String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  AdAgency         AdAgency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  Store            Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)
  AdConsumption    AdConsumption[]
  AdRecharge       AdRecharge[]

  @@index([storeId])
}

model AdAgency {
  id                 String      @id
  name               String
  platform           AdPlatform  @default(OTHER)
  rebateRate         Decimal     @default(0) @db.Decimal(5, 2)
  rebateConfig       Json?
  settlementCurrency String?
  creditTerm         String?
  contact            String?
  phone              String?
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime
  AdAccount          AdAccount[]
}

model AdConsumption {
  id               String    @id
  adAccountId      String
  accountName      String?
  agencyId         String?
  agencyName       String?
  storeId          String?
  storeName        String?
  month            String
  date             DateTime
  amount           Decimal   @db.Decimal(18, 2)
  currency         String
  estimatedRebate  Decimal?  @db.Decimal(18, 2)
  rebateRate       Decimal?  @db.Decimal(5, 2)
  campaignName     String?
  dueDate          DateTime?
  rebateDueDate    DateTime?
  isSettled        Boolean   @default(false)
  settledAt        DateTime?
  settlementFlowId String?
  voucher          String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime
  AdAccount        AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
}

model AdRecharge {
  id            String    @id
  uid           String?   @unique
  adAccountId   String
  accountName   String?
  agencyId      String
  agencyName    String?
  amount        Decimal   @db.Decimal(18, 2)
  currency      String
  rebateAmount  Decimal?  @db.Decimal(18, 2)
  rebateRate    Decimal?  @db.Decimal(5, 2)
  date          DateTime
  month         String
  paymentStatus String    @default("Pending")
  voucher       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  AdAccount     AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id                String          @id
  name              String
  accountNumber     String
  accountType       AccountType
  accountCategory   AccountCategory
  accountPurpose    String
  currency          String          @default("CNY")
  country           String          @default("CN")
  originalBalance   Decimal         @default(0) @db.Decimal(18, 2)
  initialCapital    Decimal         @default(0) @db.Decimal(18, 2)
  exchangeRate      Decimal         @default(1) @db.Decimal(10, 4)
  rmbBalance        Decimal         @default(0) @db.Decimal(18, 2)
  parentId          String?
  storeId           String?
  companyEntity     String?
  owner             String?
  notes             String          @default("")
  platformAccount   String?
  platformPassword  String?
  platformUrl       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  BankAccount       BankAccount?    @relation("BankAccountToBankAccount", fields: [parentId], references: [id])
  other_BankAccount BankAccount[]   @relation("BankAccountToBankAccount")
  Store             Store?          @relation(fields: [storeId], references: [id])
  CashFlow          CashFlow[]
}

model BatchReceipt {
  id           String   @id
  poId         String
  receiptId    String
  qty          Int
  receivedQty  Int
  ownership    Json
  receivedDate DateTime
  createdAt    DateTime @default(now())

  @@index([poId])
}

model BoxSpec {
  id          String   @id
  variantId   String
  boxLengthCm Decimal? @db.Decimal(10, 2)
  boxWidthCm  Decimal? @db.Decimal(10, 2)
  boxHeightCm Decimal? @db.Decimal(10, 2)
  qtyPerBox   Int
  isDefault   Boolean  @default(false)
  weightKg    Decimal? @db.Decimal(10, 3)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([variantId])
}

model BusinessRelation {
  id           String   @id
  sourceUID    String
  targetUID    String
  relationType String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@unique([sourceUID, targetUID, relationType])
  @@index([sourceUID])
  @@index([targetUID])
}

model BusinessUidMapping {
  id         String   @id
  entityType String
  oldId      String   @unique
  uid        String
  createdAt  DateTime @default(now())

  @@index([entityType])
  @@index([uid])
}

model CashFlow {
  id              String         @id
  uid             String?        @unique
  date            DateTime
  summary         String
  category        String
  type            CashFlowType
  amount          Decimal        @db.Decimal(18, 2)
  accountId       String
  accountName     String
  currency        String         @default("CNY")
  remark          String         @default("")
  relatedId       String?
  businessNumber  String?
  status          CashFlowStatus @default(CONFIRMED)
  isReversal      Boolean        @default(false)
  reversedById    String?
  voucher         String?
  paymentVoucher  String?
  transferVoucher String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  BankAccount     BankAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  CashFlow        CashFlow?      @relation("CashFlowToCashFlow", fields: [reversedById], references: [id])
  other_CashFlow  CashFlow[]     @relation("CashFlowToCashFlow")

  @@index([accountId])
  @@index([category])
  @@index([createdAt])
  @@index([date])
  @@index([status])
  @@index([type])
}

model CommissionRecord {
  id             String         @id
  employeeId     String
  ruleId         String
  periodLabel    String
  amount         Decimal        @db.Decimal(18, 2)
  currency       String         @default("CNY")
  details        Json?
  generatedAt    DateTime       @default(now())
  Employee       Employee       @relation(fields: [employeeId], references: [id])
  CommissionRule CommissionRule @relation(fields: [ruleId], references: [id])
}

model CommissionRule {
  id               String             @id
  name             String
  department       DepartmentEnum
  departmentId     String?
  position         String?
  type             CommissionRuleType
  config           Json
  dataSource       Json
  period           CommissionPeriod
  startDate        DateTime?
  endDate          DateTime?
  enabled          Boolean            @default(true)
  description      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  CommissionRecord CommissionRecord[]
  Department       Department?        @relation(fields: [departmentId], references: [id])

  @@index([departmentId])
}

model CompanyProfile {
  id              String   @id @default("default")
  name            String?
  address         String?
  phone           String?
  contact         String?
  bankAccount     String?
  bankAccountName String?
  bankName        String?
  taxId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
}

model Container {
  id                  String          @id
  containerNo         String          @unique
  containerType       String
  sealNo              String?
  shippingMethod      ShippingMethod
  shipCompany         String?
  vesselName          String?
  voyageNo            String?
  originPort          String?
  destinationPort     String?
  etd                 DateTime?
  eta                 DateTime?
  actualDeparture     DateTime?
  actualArrival       DateTime?
  status              ContainerStatus @default(PLANNED)
  totalVolumeCBM      Decimal?        @db.Decimal(18, 3)
  totalWeightKG       Decimal?        @db.Decimal(18, 3)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime
  declaredCurrency    String?
  declaredValue       Decimal?        @db.Decimal(18, 2)
  destinationCountry  String?
  dutyAmount          Decimal?        @db.Decimal(18, 2)
  dutyCurrency        String?
  dutyPaidAmount      Decimal?        @db.Decimal(18, 2)
  dutyPayer           String?
  exportMode          String?
  exporterId          String?
  exporterName        String?
  overseasCompanyId   String?
  overseasCompanyName String?
  platform            String?
  returnAmount        Decimal?        @db.Decimal(18, 2)
  returnCurrency      String?
  returnDate          DateTime?
  serviceMode         String?
  storeId             String?
  storeName           String?
  warehouseId         String?
  warehouseName       String?
  loadingDate         DateTime?
  OutboundBatch       OutboundBatch[]
}

model ContainerPreRecord {
  id                      String                   @id
  name                    String?
  status                  String                   @default("Draft")
  notes                   String?
  exporterId              String?
  exporterName            String?
  overseasCompanyId       String?
  overseasCompanyName     String?
  shippingMethod          String?
  originPort              String?
  destinationPort         String?
  destinationCountry      String?
  warehouseId             String?
  warehouseName           String?
  platform                String?
  storeId                 String?
  storeName               String?
  totalVolumeCBM          Decimal?                 @db.Decimal(18, 3)
  totalWeightKG           Decimal?                 @db.Decimal(18, 3)
  suggestedContainerType  String?
  containerId             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime
  outboundBatchId         String?
  outboundOrderId         String?
  formFilledAt            DateTime?
  loadingDate             DateTime?
  loadingLocation         String?
  loadingLogisticsCompany String?
  loadingProductQty       Int?
  shippingWarehouseId     String?
  shippingWarehouseName   String?
  OutboundBatch           OutboundBatch?           @relation(fields: [outboundBatchId], references: [id])
  OutboundOrder           OutboundOrder?           @relation(fields: [outboundOrderId], references: [id])
  ContainerPreRecordItem  ContainerPreRecordItem[]

  @@index([containerId])
  @@index([outboundBatchId])
  @@index([outboundOrderId])
  @@index([status])
}

model ContainerPreRecordItem {
  id                 String             @id
  preRecordId        String
  variantId          String?
  sku                String
  skuName            String?
  spec               String?
  qty                Int
  unitVolumeCBM      Decimal?           @db.Decimal(18, 6)
  unitWeightKG       Decimal?           @db.Decimal(10, 3)
  totalVolumeCBM     Decimal?           @db.Decimal(18, 3)
  totalWeightKG      Decimal?           @db.Decimal(18, 3)
  createdAt          DateTime           @default(now())
  ContainerPreRecord ContainerPreRecord @relation(fields: [preRecordId], references: [id], onDelete: Cascade)

  @@index([preRecordId])
  @@index([variantId])
}

model DeliveryOrder {
  id                     String              @id
  deliveryNumber         String              @unique
  contractId             String
  contractNumber         String
  qty                    Int
  itemQtys               Json?
  domesticTrackingNumber String?
  shippedDate            DateTime?
  status                 DeliveryOrderStatus
  tailAmount             Decimal             @db.Decimal(18, 2)
  tailPaid               Decimal             @default(0) @db.Decimal(18, 2)
  tailDueDate            DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime
  PurchaseContract       PurchaseContract    @relation(fields: [contractId], references: [id])
  InventoryLog           InventoryLog[]
  PendingInbound         PendingInbound?
}

model Department {
  id             String           @id
  name           String           @unique
  code           String?          @unique
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  CommissionRule CommissionRule[]
  Employee       Employee[]
  PurchaseOrder  PurchaseOrder[]
  User           User[]

  @@index([code])
  @@index([name])
}

model Document {
  id         String             @id
  entityType DocumentEntityType
  entityId   String
  name       String
  type       DocumentType
  fileUrl    String?
  uploadDate DateTime           @default(now())
  uploadedBy String?
  notes      String?

  @@index([entityType, entityId])
}

model Employee {
  id                     String             @id
  name                   String
  employeeNumber         String?
  department             DepartmentEnum
  departmentId           String?
  position               String
  joinDate               DateTime
  phone                  String?
  email                  String?
  status                 EmploymentStatus   @default(ACTIVE)
  responsibleInfluencers String[]
  responsibleSuppliers   String[]
  responsibleStores      String[]
  notes                  String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime
  CommissionRecord       CommissionRecord[]
  Department             Department?        @relation(fields: [departmentId], references: [id])
  VideoTask              VideoTask[]

  @@index([departmentId])
}

model ExpenseRequest {
  id                  String    @id
  uid                 String?   @unique
  date                DateTime
  summary             String
  category            String
  amount              Decimal   @db.Decimal(18, 2)
  currency            String    @default("CNY")
  businessNumber      String?
  relatedId           String?
  remark              String?
  voucher             String?
  storeId             String?
  storeName           String?
  country             String?
  departmentId        String?
  departmentName      String?
  status              String    @default("Draft")
  createdBy           String
  createdAt           DateTime  @default(now())
  submittedAt         DateTime?
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  financeAccountId    String?
  financeAccountName  String?
  paidBy              String?
  paidAt              DateTime?
  paymentFlowId       String?
  paymentVoucher      String?
  adAccountId         String?
  rebateAmount        Decimal?  @db.Decimal(18, 2)
  updatedAt           DateTime
  payeeAccount        String?
  payeeName           String?
  containerId         String?
  containerNo         String?
  overseasCompanyId   String?
  overseasCompanyName String?

  @@index([approvedAt])
  @@index([createdAt])
  @@index([createdBy])
  @@index([date])
  @@index([departmentId])
  @@index([status])
  @@index([storeId])
}

model Exporter {
  id          String   @id
  name        String
  country     String   @default("CN")
  companyType String   @default("exporter")
  contact     String?
  phone       String?
  email       String?
  address     String?
  taxId       String?
  bankName    String?
  bankAccount String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([country])
  @@index([name])
}

model GeneratedContract {
  id                 String            @id
  contractNumber     String
  purchaseOrderId    String?
  purchaseContractId String?
  snapshot           Json
  createdAt          DateTime          @default(now())
  PurchaseContract   PurchaseContract? @relation(fields: [purchaseContractId], references: [id])
  PurchaseOrder      PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseContractId])
  @@index([purchaseOrderId])
}

model InboundBatch {
  id               String         @id
  pendingInboundId String
  batchNumber      String
  warehouseId      String
  warehouseName    String
  qty              Int
  receivedDate     DateTime
  notes            String?
  createdAt        DateTime       @default(now())
  PendingInbound   PendingInbound @relation(fields: [pendingInboundId], references: [id], onDelete: Cascade)
  Warehouse        Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([pendingInboundId])
  @@index([warehouseId])
}

model IncomeRequest {
  id                  String    @id
  uid                 String?   @unique
  date                DateTime
  summary             String
  category            String
  amount              Decimal   @db.Decimal(18, 2)
  currency            String    @default("CNY")
  storeId             String?
  storeName           String?
  remark              String?
  voucher             String?
  status              String    @default("Draft")
  createdBy           String
  createdAt           DateTime  @default(now())
  submittedAt         DateTime?
  approvedBy          String?
  approvedAt          DateTime?
  rejectionReason     String?
  financeAccountId    String?
  financeAccountName  String?
  receivedBy          String?
  receivedAt          DateTime?
  paymentFlowId       String?
  paymentVoucher      String?
  updatedAt           DateTime
  containerId         String?
  containerNo         String?
  overseasCompanyId   String?
  overseasCompanyName String?

  @@index([approvedAt])
  @@index([createdAt])
  @@index([createdBy])
  @@index([date])
  @@index([status])
  @@index([storeId])
}

model Influencer {
  id                       String      @id
  accountName              String
  platform                 Platform
  accountUrl               String?
  followerCount            Int
  contactInfo              String
  category                 String
  cooperationStatus        String
  sampleStatus             String
  sampleOrderNumber        String?
  sampleTrackingNumber     String?
  sampleProductSku         String?
  sampleProductId          String?
  sampleSentAt             DateTime?
  sampleReceivedAt         DateTime?
  historicalEngagementRate Decimal?    @db.Decimal(5, 2)
  estimatedOrders          Int?
  actualOrders             Int?
  notes                    String?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime
  VideoTask                VideoTask[]
}

model InventoryLog {
  id                                                String             @id
  type                                              InventoryLogType
  status                                            InventoryLogStatus
  variantId                                         String
  qty                                               Int
  warehouseId                                       String?
  fromWarehouseId                                   String?
  toWarehouseId                                     String?
  deliveryOrderId                                   String?
  relatedOrderNo                                    String?
  notes                                             String?
  createdAt                                         DateTime           @default(now())
  updatedAt                                         DateTime
  DeliveryOrder                                     DeliveryOrder?     @relation(fields: [deliveryOrderId], references: [id])
  Warehouse_InventoryLog_fromWarehouseIdToWarehouse Warehouse?         @relation("InventoryLog_fromWarehouseIdToWarehouse", fields: [fromWarehouseId], references: [id])
  Warehouse_InventoryLog_toWarehouseIdToWarehouse   Warehouse?         @relation("InventoryLog_toWarehouseIdToWarehouse", fields: [toWarehouseId], references: [id])
  ProductVariant                                    ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  Warehouse_InventoryLog_warehouseIdToWarehouse     Warehouse?         @relation("InventoryLog_warehouseIdToWarehouse", fields: [warehouseId], references: [id])

  @@index([deliveryOrderId])
  @@index([status])
  @@index([type])
  @@index([variantId])
  @@index([warehouseId])
}

model InventoryMovement {
  id                 String                @id
  variantId          String
  location           InventoryLocation
  movementType       InventoryMovementType
  qty                Int
  qtyBefore          Int
  qtyAfter           Int
  unitCost           Decimal?              @db.Decimal(18, 2)
  totalCost          Decimal?              @db.Decimal(18, 2)
  currency           String?
  relatedOrderId     String?
  relatedOrderType   String?
  relatedOrderNumber String?
  operator           String?
  operationDate      DateTime
  notes              String?
  createdAt          DateTime              @default(now())
  ProductVariant     ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model InventoryOwnershipLedger {
  id                  String         @id
  variantId           String
  skuId               String?
  productName         String?
  qty                 Int
  unit                String?        @default("pcs")
  bizType             String
  bizNo               String?
  relatedOrderId      String?
  relatedOrderType    String?
  fromWarehouseId     String?
  fromWarehouseName   String?
  toWarehouseId       String?
  toWarehouseName     String?
  fromOwnerType       String?
  fromOwnerId         String?
  fromOwnerName       String?
  toOwnerType         String?
  toOwnerId           String?
  toOwnerName         String?
  country             String?
  platform            String?
  storeId             String?
  storeName           String?
  sourceBatchNumber   String?
  outboundBatchId     String?
  outboundBatchNumber String?
  eventTime           DateTime       @default(now())
  createdAt           DateTime       @default(now())
  ProductVariant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([bizNo])
  @@index([bizType])
  @@index([country])
  @@index([eventTime])
  @@index([platform])
  @@index([storeId])
  @@index([variantId])
}

model InventoryStock {
  id             String            @id
  variantId      String
  storeId        String?
  location       InventoryLocation
  qty            Int               @default(0)
  updatedAt      DateTime
  createdAt      DateTime          @default(now())
  Store          Store?            @relation(fields: [storeId], references: [id])
  ProductVariant ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, location, storeId])
  @@index([variantId])
}

model LogisticsChannel {
  id                String              @id
  name              String
  channelCode       String
  contact           String
  phone             String
  queryUrl          String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  LogisticsCost     LogisticsCost[]
  LogisticsTracking LogisticsTracking[]
}

model LogisticsCost {
  id                 String            @id
  outboundBatchId    String?
  logisticsChannelId String?
  costType           String
  amount             Decimal           @db.Decimal(18, 2)
  currency           String
  paymentType        String
  creditDays         Int?
  dueDate            DateTime?
  paymentStatus      String
  paidDate           DateTime?
  invoiceNumber      String?
  invoiceStatus      String?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  LogisticsChannel   LogisticsChannel? @relation(fields: [logisticsChannelId], references: [id])
  OutboundBatch      OutboundBatch?    @relation(fields: [outboundBatchId], references: [id])

  @@index([logisticsChannelId])
  @@index([outboundBatchId])
}

model LogisticsTracking {
  id                  String           @id
  internalOrderNumber String
  trackingNumber      String           @unique
  channelId           String
  storeId             String?
  currentStatus       LogisticsStatus
  shippedDate         DateTime
  lastUpdatedAt       DateTime
  transportDays       Int?
  orderId             String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime
  LogisticsChannel    LogisticsChannel @relation(fields: [channelId], references: [id])
  Store               Store?           @relation(fields: [storeId], references: [id])
  TrackingEvent       TrackingEvent[]
}

model MonthlyBill {
  id                        String    @id
  uid                       String?   @unique
  month                     String
  billCategory              String
  billType                  String
  agencyId                  String?
  agencyName                String?
  adAccountId               String?
  accountName               String?
  supplierId                String?
  supplierName              String?
  factoryId                 String?
  factoryName               String?
  totalAmount               Decimal   @db.Decimal(18, 2)
  currency                  String    @default("CNY")
  rebateAmount              Decimal   @default(0) @db.Decimal(18, 2)
  netAmount                 Decimal   @db.Decimal(18, 2)
  consumptionIds            String?
  rechargeIds               String?
  status                    String    @default("Draft")
  createdBy                 String
  createdAt                 DateTime  @default(now())
  submittedToFinanceAt      DateTime?
  paymentApplicationVoucher String?
  financeReviewedBy         String?
  financeReviewedAt         DateTime?
  submittedAt               DateTime?
  approvedBy                String?
  approvedAt                DateTime?
  cashierApprovedBy         String?
  cashierApprovedAt         DateTime?
  rejectionReason           String?
  paidBy                    String?
  paidAt                    DateTime?
  paymentMethod             String?
  paymentAccountId          String?
  paymentAccountName        String?
  paymentVoucher            String?
  paymentFlowId             String?
  paymentVoucherNumber      String?
  paymentRemarks            String?
  notes                     String?
  updatedAt                 DateTime

  @@index([approvedAt])
  @@index([billCategory])
  @@index([createdAt])
  @@index([month])
  @@index([status])
}

model Notification {
  id          String                  @id
  type        NotificationType
  title       String
  message     String
  relatedId   String
  relatedType NotificationRelatedType
  read        Boolean                 @default(false)
  readAt      DateTime?
  actionUrl   String?
  priority    NotificationPriority    @default(medium)
  createdAt   DateTime                @default(now())

  @@index([read])
  @@index([relatedId, relatedType])
}

model OrderItem {
  id            String        @id
  orderId       String
  sku           String
  skuId         String?
  skuName       String?
  spec          String?
  quantity      Int
  unitPrice     Decimal       @db.Decimal(18, 2)
  totalAmount   Decimal       @db.Decimal(18, 2)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  PurchaseOrder PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderTracking {
  id         String              @id
  poId       String
  status     OrderTrackingStatus
  statusDate DateTime
  notes      String?
  createdAt  DateTime            @default(now())

  @@index([poId])
}

model OutboundBatch {
  id                   String               @id
  outboundOrderId      String
  batchNumber          String
  warehouseId          String
  warehouseName        String
  qty                  Int
  shippedDate          DateTime
  destination          String?
  trackingNumber       String?
  shippingMethod       ShippingMethod?
  vesselName           String?
  vesselVoyage         String?
  portOfLoading        String?
  portOfDischarge      String?
  eta                  DateTime?
  actualDepartureDate  DateTime?
  actualArrivalDate    DateTime?
