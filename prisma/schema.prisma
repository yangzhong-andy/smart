  dueDate      DateTime?
  videoUrl     String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime
  Employee     Employee?       @relation(fields: [assigneeId], references: [id])
  Influencer   Influencer?     @relation(fields: [influencerId], references: [id])
  Product      Product?        @relation(fields: [productId], references: [id])
}

model Warehouse {
  id                                                   String            @id
  code                                                 String            @unique
  name                                                 String
  address                                              String?
  contact                                              String?
  phone                                                String?
  manager                                              String?
  location                                             InventoryLocation
  type                                                 WarehouseType     @default(DOMESTIC)
  isActive                                             Boolean           @default(true)
  capacity                                             Int?
  notes                                                String?
  createdAt                                            DateTime          @default(now())
  updatedAt                                            DateTime
  InboundBatch                                         InboundBatch[]
  InventoryLog_InventoryLog_fromWarehouseIdToWarehouse InventoryLog[]    @relation("InventoryLog_fromWarehouseIdToWarehouse")
  InventoryLog_InventoryLog_toWarehouseIdToWarehouse   InventoryLog[]    @relation("InventoryLog_toWarehouseIdToWarehouse")
  InventoryLog_InventoryLog_warehouseIdToWarehouse     InventoryLog[]    @relation("InventoryLog_warehouseIdToWarehouse")
  OutboundBatch                                        OutboundBatch[]
  OutboundOrder                                        OutboundOrder[]
  Stock                                                Stock[]
  StockLog                                             StockLog[]

  @@index([code])
  @@index([location])
  @@index([type])
}

